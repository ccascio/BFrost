{
  "name": "bfrost",
  "version": "0.2.0",
  "description": "Worker-first local AI operations platform — every capability is a pluggable worker",
  "license": "MIT",
  "homepage": "https://bfrost.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccascio/BFrost.git"
  },
  "bugs": {
    "url": "https://github.com/ccascio/BFrost/issues"
  },
  "keywords": [
    "ai",
    "local-first",
    "self-hosted",
    "automation",
    "agents",
    "scheduler",
    "llm",
    "lm-studio",
    "ollama"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bfrost": "bin/bfrost.mjs"
  },
  "files": [
    "bin",
    "dist",
    "!dist/**/*.test.js",
    "web/dist",
    ".env.example",
    "docs",
    "!docs/launch"
  ],
  "scripts": {
    "clean": "rm -rf dist web/dist",
    "clean:server": "rm -rf dist",
    "build": "npm run clean && tsc && vite build",
    "build:server": "npm run clean:server && tsc",
    "build:web": "vite build",
    "check:web": "tsc --noEmit -p web/tsconfig.json",
    "smoke:web": "node scripts/web-smoke.mjs",
    "start": "node scripts/daemon.mjs",
    "prepack": "npm run build",
    "stop": "node scripts/stop.mjs",
    "logs": "node scripts/logs.mjs",
    "install-service": "node scripts/install-service.mjs",
    "uninstall-service": "node scripts/uninstall-service.mjs",
    "test": "rm -rf dist && tsc && node --test $(find dist -name '*.test.js' -print | sort) && npm run check:web",
    "task": "node dist/cron.js",
    "dev": "node scripts/dev.mjs",
    "dev:watch": "tsc --watch",
    "dev:web": "vite",
    "check:manifest": "node scripts/check-manifest-enums.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/nodemailer": "^8.0.0",
    "ai": "^6.0.154",
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^5.6.2",
    "dompurify": "^3.4.3",
    "dotenv": "^17.4.1",
    "esbuild": "^0.28.0",
    "imapflow": "^1.3.3",
    "marked": "^18.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "telegraf": "^4.16.3",
    "zod": "^3.25.76"
  }
}
