TELEGRAM_BOT_TOKEN=your_bot_token_here
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BIN=/Applications/LM Studio.app/Contents/Resources/app/.webpack/lms
ALLOWED_USER_ID=123456789
WHISPER_MODEL_PATH=./models/ggml-large-v3-turbo-q5_0.bin
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_FALLBACK_ALIASES=gpt-5.4-mini,claude-sonnet-4.6
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
MEMORY_STORE_PATH=./data/memory.json
CONVERSATION_STORE_PATH=./data/conversations.json
APP_DB_PATH=./data/bfrost.sqlite
NEWS_STORE_DIR=./data/news
RESEARCH_STORE_DIR=./data/research
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_USERNAME=
# Bind address. Keep on 127.0.0.1 (loopback) unless you understand the exposure;
# a non-loopback bind makes the dashboard reachable from your network.
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3030
ADMIN_STORE_DIR=./data/admin
# Set a password to require login on the dashboard. Empty = no auth (only safe on a
# machine you fully trust). Can also be set from Settings > Platform & security.
ADMIN_PASSWORD=
ADMIN_SESSION_TTL_HOURS=24
JOB_LLM_TIMEOUT_MS=600000
BFROST_WORKER_PATHS=./workers/local,./workers
# Allow local workers that ship executable code to compile and run. Off by default;
# turn on only for worker code you trust. Toggle from Settings > Platform & security.
BFROST_ENABLE_LOCAL_WORKER_CODE=false
